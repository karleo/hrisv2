APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# iClock ADMS push — your PC LAN IP + port (not localhost, not the device IP).
# Example: http://192.168.1.88:8000
BIOMETRIC_PUSH_BASE_URL=

# App default timezone (schedules, etc.). Biometric punch times use each device's timezone in Biometric → Connectivity, not APP_TIMEZONE.
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Face login: "local" (dev only; use FACE_LOGIN_LOCAL_MODE=hash in tests) or "rekognition" (requires AWS keys).
FACE_LOGIN_DRIVER=local
FACE_LOGIN_LOCAL_MODE=ahash
FACE_LOGIN_LOCAL_AHASH_MAX_DISTANCE=34
FACE_LOGIN_SIMILARITY_THRESHOLD=90
FACE_LOGIN_DISK=local

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=hrisv2-local-app
REVERB_APP_KEY=hrisv2-local-key
REVERB_APP_SECRET=hrisv2-local-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Optional: PHP 8.3+ for Vite/Wayfinder when `php` on PATH is an older version (Windows/Laragon).
# WAYFINDER_PHP=C:/laragon/bin/php/php-8.3.30-Win32-vs16-x64/php.exe
# Optional: full command override (e.g. Herd): WAYFINDER_COMMAND=herd php artisan wayfinder:generate --no-interaction
